<div class="container mt-4">
  <div class="chat-container border rounded shadow-sm bg-light p-3 d-flex flex-column h-100">
    <div class="messages-box overflow-auto mb-3 p-2 flex-grow-1 bg-white border rounded">
      <div class="p-2 rounded bg-secondary text-white d-inline-block">
        Tell me What?
      </div>
    </div>
    <div class="input-area mt-auto">
      <%= simple_form_for @chat do |f| %>
        <%= f.input :question,input_html: { class: "bg-white py-0 border border-0 mb-0" }, label: false, placeholder: "Ask me What?" %>
        <div class="d-flex justify-content-end">
          <%= f.button :submit, "➝", class: "arrow-btn" %>
        </div>
      <% end %>

    </div>
  </div>
</div>
