<div class="container d-flex flex-column align-items-center">
  <div class="card my-5 p-2" style="width: 18rem;">
    <%= image_tag "https://picsum.photos/200/200", alt: "Le Wagon", width: 200, class: "card-img-top" %>
    <div class="card-body">
      <h5 class="card-title">Tell Me What?</h5>
      <p class="card-text fw-semibold">starting at 4,90$/month</p>
      <p class="card-text text-secondary">Learn about your favorite artist's gear</p>
    </div>
  </div>
  <div class="d-flex flex-column">
    <%= link_to "Sign Up", new_user_registration_path, class: "btn btn-dark btn-lg my-2" %>
    <%= link_to "Sign In", new_user_session_path, class: "btn btn-outline-dark btn-lg" %>
  </div>
</div>
